# AHTML — environment variables
#
# Copy this file to `.env` (which is gitignored and never published)
# and fill in the API keys you have. At least ONE is required to run
# the LLM comprehension benchmark.
#
#   bash scripts/run-llm-benchmark.sh
#
# Each key gets a separate row in the benchmark output (cost,
# latency, accuracy). Missing keys are skipped silently.

# ─────────────────────────────────────────────────────────────────
# OpenAI — gpt-4o-mini (cheapest, fast)
#   https://platform.openai.com/api-keys
#   Pricing (May 2026): $0.15 / 1M in, $0.60 / 1M out
OPENAI_API_KEY=

# Anthropic — claude-haiku-4.5 (cheapest Claude)
#   https://console.anthropic.com/settings/keys
#   Pricing (May 2026): $1.00 / 1M in, $5.00 / 1M out
ANTHROPIC_API_KEY=

# Google AI Studio — gemini-2.5-flash
#   https://aistudio.google.com/app/apikey
#   Pricing (May 2026): $0.075 / 1M in, $0.30 / 1M out  (cheapest of the four)
GEMINI_API_KEY=

# Groq — llama-3.3-70b-versatile (extremely fast, decent quality)
#   https://console.groq.com/keys
#   Pricing (May 2026): $0.59 / 1M in, $0.79 / 1M out
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Optional — override the public URL embedded in snapshots.
# Defaults to https://ahtml.dev when not set.
# SITE_URL=https://ahtml.dev
