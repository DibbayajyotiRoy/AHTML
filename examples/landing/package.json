{
  "name": "ahtml-landing",
  "version": "0.1.0",
  "private": true,
  "description": "ahtml.dev — the marketing landing page. Built with Next.js. Dogfoods @ahtmljs/next on every route: /.well-known/ahtml.json, /ahtml/*, /llms.txt, MCP, OpenAPI.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm --prefix ../.. run build --workspace=@ahtmljs/schema --workspace=@ahtmljs/extract --workspace=@ahtmljs/next",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ahtmljs/next": "^1.1.0",
    "@ahtmljs/schema": "^1.1.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gpt-tokenizer": "^3.4.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
