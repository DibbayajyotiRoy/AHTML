{
  "name": "ahtml-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "AHTML — the HTML of the agent web.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run test:ux && npm run test:docs",
    "test:unit": "npm run test --workspaces --if-present",
    "test:ux": "tsx --test tests/ux/*.test.ts",
    "test:docs": "tsx --test tests/docs/*.test.ts",
    "test:web-reality": "tsx --test tests/web-reality/__tests__/*.test.ts",
    "benchmark:llm": "bash scripts/run-llm-benchmark.sh",
    "benchmark": "npm run start --workspace examples/benchmark",
    "benchmark:why": "npm run start --workspace examples/why-ahtml",
    "demo": "npm run dev --workspace examples/landing",
    "test:conformance": "tsx --test tests/conformance/*.test.ts",
    "test:budgets": "tsx --test tests/budgets/*.test.ts",
    "smoke:imports": "node build-tools/smoke-imports.mjs",
    "check:roadmap": "node scripts/roadmap-coverage.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ahtml-agent-pinned-1-0-0": "npm:@ahtmljs/agent@^1.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
