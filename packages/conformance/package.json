{
  "name": "@ahtmljs/conformance",
  "version": "1.1.0",
  "description": "Language-agnostic AHTML conformance corpus and runner — versioned fixtures covering every RFC-2119 MUST in SPEC.md, with signed result attestations for third-party implementations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "corpus",
    "impl-ts.manifest.json",
    "impl-py.manifest.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DibbayajyotiRoy/AHTML.git",
    "directory": "packages/conformance"
  },
  "homepage": "https://github.com/DibbayajyotiRoy/AHTML#readme",
  "bugs": {
    "url": "https://github.com/DibbayajyotiRoy/AHTML/issues",
    "email": "rdibbayajyoti@gmail.com"
  },
  "author": {
    "name": "Dibbayajyoti Roy",
    "email": "rdibbayajyoti@gmail.com",
    "url": "https://github.com/DibbayajyotiRoy"
  },
  "keywords": [
    "ahtml",
    "conformance",
    "agent-web",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@ahtmljs/schema": "1.0.0",
    "@ahtmljs/agent": "1.0.0"
  }
}
