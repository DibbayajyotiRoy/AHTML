{
  "name": "@ahtmljs/hono",
  "version": "0.9.0",
  "description": "AHTML adapter for Hono — mount /ahtml, /.well-known/ahtml.json, /ahtml/mcp.json, /ahtml/openapi.json, and /llms.txt on any Hono app. Runs on Node, Bun, Deno, Cloudflare Workers, and AWS Lambda.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "repository": { "type": "git", "url": "git+https://github.com/DibbayajyotiRoy/AHTML.git", "directory": "packages/hono" },
  "homepage": "https://github.com/DibbayajyotiRoy/AHTML#readme",
  "bugs": { "url": "https://github.com/DibbayajyotiRoy/AHTML/issues", "email": "rdibbayajyoti@gmail.com" },
  "author": { "name": "Dibbayajyoti Roy", "email": "rdibbayajyoti@gmail.com", "url": "https://github.com/DibbayajyotiRoy" },
  "keywords": ["ahtml", "hono", "mcp", "model-context-protocol", "llms-txt", "openapi", "json-ld", "agent-web", "ai", "edge", "cloudflare-workers", "bun", "deno", "well-known"],
  "engines": { "node": ">=20" },
  "license": "MIT",
  "dependencies": {
    "@ahtmljs/schema": "0.9.0"
  },
  "peerDependencies": {
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "hono": { "optional": true }
  }
}
