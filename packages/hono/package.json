{
  "name": "@ahtmljs/hono",
  "version": "0.9.3",
  "description": "AHTML adapter for Hono — mount /ahtml, /.well-known/ahtml.json, /ahtml/mcp.json, /ahtml/openapi.json, and /llms.txt on any Hono app. Runs on Node, Bun, Deno, Cloudflare Workers, and AWS Lambda.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node ../../build-tools/cjs-postbuild.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DibbayajyotiRoy/AHTML.git",
    "directory": "packages/hono"
  },
  "homepage": "https://github.com/DibbayajyotiRoy/AHTML#readme",
  "bugs": {
    "url": "https://github.com/DibbayajyotiRoy/AHTML/issues",
    "email": "rdibbayajyoti@gmail.com"
  },
  "author": {
    "name": "Dibbayajyoti Roy",
    "email": "rdibbayajyoti@gmail.com",
    "url": "https://github.com/DibbayajyotiRoy"
  },
  "keywords": [
    "ahtml",
    "hono",
    "mcp",
    "model-context-protocol",
    "llms-txt",
    "openapi",
    "json-ld",
    "agent-web",
    "ai",
    "edge",
    "cloudflare-workers",
    "bun",
    "deno",
    "well-known"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@ahtmljs/schema": "0.9.3"
  },
  "peerDependencies": {
    "hono": ">=4"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "hono": "^4.12.25"
  }
}
