{
  "name": "@ahtmljs/next",
  "version": "0.9.4",
  "description": "Next.js plugin for AHTML. Turns your existing Next.js app into an MCP server, an OpenAPI provider, a JSON-LD source, and a token-optimal semantic snapshot — all from one plugin. Zero migration.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./handler": {
      "import": {
        "types": "./dist/handler.d.ts",
        "default": "./dist/handler.js"
      },
      "require": {
        "types": "./dist/cjs/handler.d.ts",
        "default": "./dist/cjs/handler.js"
      }
    },
    "./well-known": {
      "import": {
        "types": "./dist/well-known.d.ts",
        "default": "./dist/well-known.js"
      },
      "require": {
        "types": "./dist/cjs/well-known.d.ts",
        "default": "./dist/cjs/well-known.js"
      }
    },
    "./llms-txt": {
      "import": {
        "types": "./dist/llms-txt.d.ts",
        "default": "./dist/llms-txt.js"
      },
      "require": {
        "types": "./dist/cjs/llms-txt.d.ts",
        "default": "./dist/cjs/llms-txt.js"
      }
    },
    "./extractors": {
      "import": {
        "types": "./dist/extractors/index.d.ts",
        "default": "./dist/extractors/index.js"
      },
      "require": {
        "types": "./dist/cjs/extractors/index.d.ts",
        "default": "./dist/cjs/extractors/index.js"
      }
    },
    "./mcp": {
      "import": {
        "types": "./dist/mcp.d.ts",
        "default": "./dist/mcp.js"
      },
      "require": {
        "types": "./dist/cjs/mcp.d.ts",
        "default": "./dist/cjs/mcp.js"
      }
    },
    "./openapi": {
      "import": {
        "types": "./dist/openapi.d.ts",
        "default": "./dist/openapi.js"
      },
      "require": {
        "types": "./dist/cjs/openapi.d.ts",
        "default": "./dist/cjs/openapi.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node ../../build-tools/cjs-postbuild.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DibbayajyotiRoy/AHTML.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/DibbayajyotiRoy/AHTML#readme",
  "bugs": {
    "url": "https://github.com/DibbayajyotiRoy/AHTML/issues",
    "email": "rdibbayajyoti@gmail.com"
  },
  "author": {
    "name": "Dibbayajyoti Roy",
    "email": "rdibbayajyoti@gmail.com",
    "url": "https://github.com/DibbayajyotiRoy"
  },
  "keywords": [
    "ahtml",
    "nextjs",
    "next",
    "plugin",
    "agent",
    "agent-web",
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "llms-txt",
    "openapi",
    "json-ld",
    "semantic-web",
    "crawler"
  ],
  "dependencies": {
    "@ahtmljs/schema": "0.9.4"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "license": "MIT"
}
