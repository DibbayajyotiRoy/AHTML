    "url": "https://github.com/DibbayajyotiRoy"
  },
  "keywords": [
    "ahtml",
    "agent",
    "agent-web",
    "semantic-web",
    "ai",
    "llm",
    "crawler",
    "mcp",
    "model-context-protocol",
    "llms-txt",
    "json-ld",
    "schema",
    "openapi"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
